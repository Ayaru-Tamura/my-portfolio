---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <h1 class="page-title">Contact</h1>

  <form
    action="https://formspree.io/f/xnjlnpnj"
    method="POST"
    class="section-block max-w-xl"
  >
    <div class="mb-4">
      <label class="block mb-2 text-gray-300">お名前</label>
      <input
        type="text"
        name="name"
        required
        class="w-full p-2 rounded bg-zinc-800 text-white placeholder-gray-400 focus:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-gray-500"
      />
    </div>

    <div class="mb-4">
      <label class="block mb-2 text-gray-300">メールアドレス</label>
      <input
        type="email"
        name="email"
        required
        class="w-full p-2 rounded bg-zinc-800 text-white placeholder-gray-400 focus:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-gray-500"
      />
    </div>

    <div class="mb-4">
      <label class="block mb-2 text-gray-300">お問い合わせ内容</label>
      <textarea
        name="message"
        rows="5"
        required
        class="w-full p-2 rounded bg-zinc-800 text-white placeholder-gray-400 focus:bg-zinc-800 focus:outline-none focus:ring-2 focus:ring-gray-500"
      ></textarea>
    </div>

    <button
      type="submit"
      class="px-4 py-2 bg-[#333333] rounded text-white"
    >
      送信
    </button>
  </form>
</Layout>