---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <h1 class="text-5xl font-semibold mb-6 text-white">Works</h1>

<div class="mb-8">
  <h2 class="text-2xl font-bold text-white mb-2">ポートフォリオサイト</h2>
  <p class="text-lg text-white mb-2">
    Astroを使用して制作したポートフォリオサイトです。
    自己紹介やスキル、制作物を掲載するために作成しました。
  </p>
  <p class="text-sm text-gray-400 mb-2">
    使用技術：Astro / HTML / CSS / Git / Vercel
  </p>
  <div class="flex gap-4">
    <a href="https://github.com/Ayaru-Tamura/my-portfolio" target="_blank">GitHub</a>
    <a href="https://my-portfolio-five-lac-85.vercel.app/" target="_blank">Site</a>
  </div>
</div>
</Layout>
