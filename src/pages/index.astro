---
import Layout from '../layouts/Layout.astro';
const name = "Tamura Ayaru";
---

<Layout>
  <div class="mb-12">
    <h1 class="text-5xl font-semibold mb-8 text-white">{name}</h1>

    <p class="text-base leading-loose text-white max-w-2xl">
      人を責めずに、仕組みを変える。<br />
      現場理解とITの視点を活かし、
      業務改善につながる仕組みづくりを目指しています。
    </p>
  </div>

  <div class="flex flex-wrap gap-4">
    <a href="/about" class="px-4 py-2 bg-[#333333] rounded text-white">About</a>
    <a href="/skills" class="px-4 py-2 bg-[#333333] rounded text-white">Skills</a>
    <a href="/works" class="px-4 py-2 bg-[#333333] rounded text-white">Works</a>
    <a href="/contact" class="px-4 py-2 bg-[#333333] rounded text-white">Contact</a>
  </div>
</Layout>